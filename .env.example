# App (en Render: https://tu-servicio.onrender.com)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase (https://supabase.com)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Admin — emails con acceso a /admin (separados por coma)
ADMIN_EMAILS=juank.gagliano@gmail.com
# Legacy (opcional): contraseña del panel viejo / cookie admin
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=

# Contacto corredores (WhatsApp sin + ni espacios, ej. 5492664123456)
NEXT_PUBLIC_WHATSAPP_PHONE=
NEXT_PUBLIC_CONTACT_EMAIL=soporte.actionsnap@gmail.com

# Email post-compra (https://resend.com) — opcional
RESEND_API_KEY=
RESEND_FROM_EMAIL=Action Snap <fotos@tudominio.com>

# Cloudflare R2 — storage de fotos nuevas (recomendado; 10 GB free)
# Dashboard: https://dash.cloudflare.com → R2 → Manage R2 API Tokens
# 1. Creá 2 buckets: hd-originals (privado) y public-previews (público o con custom domain)
# 2. En public-previews: Settings → Public access → Connect custom domain O R2.dev subdomain
# 3. Pegá la URL pública base (sin barra final) en R2_PUBLIC_BASE_URL
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_HD=hd-originals
R2_BUCKET_PREVIEW=public-previews
R2_PUBLIC_BASE_URL=https://pub-xxxx.r2.dev

# Cloudinary — opcional (solo fotos legacy)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=

# Pagos — Mercado Pago Connect (recomendado Argentina) o Stripe
# Token de la aplicación Action Snap (credenciales de producción o test).
MERCADOPAGO_ACCESS_TOKEN=
# OAuth Connect — crear app en https://www.mercadopago.com.ar/developers/panel/app
MERCADOPAGO_CLIENT_ID=
MERCADOPAGO_CLIENT_SECRET=
# Opcional: si no se define, usa {NEXT_PUBLIC_APP_URL}/api/mercadopago/callback
# MERCADOPAGO_REDIRECT_URI=https://actionsnap.store/api/mercadopago/callback
# PKCE OAuth (default false). Poné true solo si en el panel MP está habilitado PKCE.
# MERCADOPAGO_OAUTH_PKCE=false
# Opcional: endpoint de autorización (default https://auth.mercadopago.com/authorization)
# MERCADOPAGO_AUTH_URL=https://auth.mercadopago.com/authorization
# PAYMENT_PROVIDER=mercadopago
# PAYMENT_PROVIDER=stripe

# Stripe — pagos internacionales (https://stripe.com)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

DOWNLOAD_SIGNING_SECRET=

# Seguridad — Cloudflare Turnstile (anti-robot, gratis)
# https://dash.cloudflare.com → Turnstile → Add site
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
