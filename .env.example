# App (en Render: https://tu-servicio.onrender.com)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase (https://supabase.com)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Admin — contraseña del panel /admin (recomendado en producción)
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=

# Contacto corredores (WhatsApp sin + ni espacios, ej. 5492664123456)
NEXT_PUBLIC_WHATSAPP_PHONE=
NEXT_PUBLIC_CONTACT_EMAIL=

# Email post-compra (https://resend.com) — opcional
RESEND_API_KEY=
RESEND_FROM_EMAIL=Victor Films <fotos@tudominio.com>

# Cloudinary — opcional
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=

# Google Cloud Vision — OCR de dorsales (pausado por defecto en prod)
# Guía paso a paso: COMO-CONFIGURAR-GOOGLE-VISION.md
# Para reactivar IA más adelante: DETECTION_DISABLED=false y credenciales abajo.
DETECTION_DISABLED=true
# DETECTION_USE_CLOUD=true
# GOOGLE_CLIENT_EMAIL=
# GOOGLE_PRIVATE_KEY=
# GOOGLE_VISION_API_KEY=

# Pagos — Mercado Pago Connect (recomendado Argentina) o Stripe
# Token de la aplicación Action Snap (credenciales de producción o test).
MERCADOPAGO_ACCESS_TOKEN=
# OAuth Connect — crear app en https://www.mercadopago.com.ar/developers/panel/app
MERCADOPAGO_CLIENT_ID=
MERCADOPAGO_CLIENT_SECRET=
# Opcional: si no se define, usa {NEXT_PUBLIC_APP_URL}/api/mercadopago/callback
# MERCADOPAGO_REDIRECT_URI=https://actionsnap.store/api/mercadopago/callback
# Opcional: país de autorización (default Argentina)
# MERCADOPAGO_AUTH_URL=https://auth.mercadopago.com.ar/authorization
# PAYMENT_PROVIDER=mercadopago
# PAYMENT_PROVIDER=stripe

# Stripe — pagos internacionales (https://stripe.com)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

DOWNLOAD_SIGNING_SECRET=

# Seguridad — Cloudflare Turnstile (anti-robot, gratis)
# https://dash.cloudflare.com → Turnstile → Add site
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
